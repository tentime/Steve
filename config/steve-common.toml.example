# AI API Configuration
[ai]
    # AI provider to use: 'groq' (FASTEST, FREE), 'openai', or 'gemini'
    provider = "groq"

# API Key Configuration
# NOTE: Currently all providers read from this single key field.
# Put your Groq/Gemini/OpenAI key here depending on which provider you chose above.
[openai]
    # Your API key (required)
    apiKey = "your-api-key-here"
    
    # Model to use (only applies to OpenAI provider)
    model = "gpt-4-turbo-preview"
    
    # Maximum tokens per API request
    maxTokens = 8000
    
    # Temperature (0.0-2.0, lower is more deterministic)
    temperature = 0.7

[behavior]
    # Ticks between action checks (20 ticks = 1 second)
    actionTickDelay = 20
    
    # Allow Steves to respond in chat
    enableChatResponses = true
    
    # Maximum number of Steves that can be active simultaneously
    maxActiveSteves = 10
